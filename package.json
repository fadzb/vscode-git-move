{
  "publisher": "fadzb",
  "name": "vscode-git-move",
  "displayName": "Git Move",
  "description": "Uses git mv staging when moving files in the VS Code explorer, preserving git history",
  "version": "0.0.7",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/fadzb/vscode-git-move"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Git Move",
      "properties": {
        "gitMove.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic git staging when moving files in the VS Code explorer"
        },
        "gitMove.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Show a notification each time a file rename is staged in git"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
